  {
   "cell_type": "markdown",
   "id": "8f0fcd7c-b890-4a61-b52d-f502ccb40223",
   "metadata": {},
   "source": [
    "Outlier Detection (IQR Method)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "4b35b807-2438-4111-9cb0-75ed5c03fa00",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "acceleration_x: 11594 outliers\n",
      "acceleration_y: 1588 outliers\n",
      "acceleration_z: 12637 outliers\n",
      "gyro_x: 225 outliers\n",
      "gyro_y: 3004 outliers\n",
      "gyro_z: 134 outliers\n",
      "acc_mag: 9761 outliers\n"
     ]
    }
   ],
   "source": [
    "def detect_outliers_iqr(data, column):\n",
    "    Q1 = data[column].quantile(0.25)\n",
    "    Q3 = data[column].quantile(0.75)\n",
    "    IQR = Q3 - Q1\n",
    "    lower = Q1 - 1.5 * IQR\n",
    "    upper = Q3 + 1.5 * IQR\n",
    "    return data[(data[column] < lower) | (data[column] > upper)]\n",
    "for col in sensor_cols:##Count Outliers Per Feature\n",
    "    outliers = detect_outliers_iqr(df, col)\n",
    "    print(f\"{col}: {len(outliers)} outliers\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e284cf1b-8469-46a6-8745-1e44317949ee",
   "metadata": {},
   "source": [
    " Remove Extreme Outliers"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 20,
   "id": "ece1f44e-70bd-4955-afc2-5d3ac865609c",
   "metadata": {},
   "outputs": [],
   "source": [
    "for col in sensor_cols:\n",
    "    Q1 = df[col].quantile(0.25)\n",
    "    Q3 = df[col].quantile(0.75)\n",
    "    IQR = Q3 - Q1\n",
    "    df = df[(df[col] >= Q1 - 3*IQR) & (df[col] <= Q3 + 3*IQR)]\n"
   ]
  },
